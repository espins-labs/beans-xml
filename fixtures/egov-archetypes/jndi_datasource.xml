<beans xmlns:jee="http://www.springframework.org/schema/jee">
<jee:jndi-lookup id="dataSource" jndi-name="java:comp/env/jdbc/ExampleDS" environment-ref="jndiEnvironment"/>
<bean id="jndiEnvironment" class="com.example.util.PropertiesFactoryBean">
<property name="location" value="classpath:jndi.properties"/>
</bean>
<bean id="widgetRepository" class="com.example.WidgetRepository">
<property name="dataSource" ref="dataSource"/>
</bean>
</beans>
